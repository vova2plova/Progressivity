# Server
SERVER_PORT=8080
# Same-origin production behind Caddy can keep this empty.
CORS_ALLOWED_ORIGINS=

# Database
DB_USER=
DB_PASSWORD=
DB_NAME=progressivity
# docker-compose.prod.yml uses the internal postgres service on 5432.
DB_SSLMODE=disable

# JWT
# Generate long random secrets on the VPS before first start.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Logging
LOG_LEVEL=info
